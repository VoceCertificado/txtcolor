{
  "name": "txt-color",
  "displayName": "TXT Color",
  "description": "A beautiful color highlighting extension for plain text and configuration-style files, compatible with VS Code, Kiro, and other VS Code-based IDEs.",
  "version": "0.2.4",
  "publisher": "VoceCertificado",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VoceCertificado/txtcolor"
  },
  "homepage": "https://github.com/VoceCertificado/txtcolor#readme",
  "bugs": {
    "url": "https://github.com/VoceCertificado/txtcolor/issues"
  },
  "galleryBanner": {
    "color": "#F08C35",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "txt",
    "text",
    "plain text",
    "log",
    "logs",
    "ini",
    "conf",
    "cfg",
    "env",
    "dotenv",
    "properties",
    "toml",
    "editorconfig",
    "gitconfig",
    "configuration",
    "config",
    "key-value",
    "syntax",
    "highlight",
    "highlighting"
  ],
  "contributes": {
    "languages": [
      {
        "id": "txt",
        "aliases": [
          "TXT",
          "TXT Color",
          "TXT Syntax",
          "TXT highlight",
          "Text",
          "Text Color",
          "Text Syntax",
          "Text highlight"
        ],
        "extensions": [
          ".txt",
          ".log",
          ".ini",
          ".conf",
          ".cfg",
          ".env",
          ".properties",
          ".toml",
          ".editorconfig",
          ".gitconfig"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "txt",
        "scopeName": "source.txt",
        "path": "./syntaxes/txt.tmLanguage.json"
      }
    ]
  }
}