{
  "comments": {
    "lineComment": "#",
    "blockComment": [";", ""]
  },
  "brackets": [
    ["[", "]"],
    ["{", "}"],
    ["(", ")"],
    ["<", ">"],
    ["«", "»"]
  ],
  "autoClosingPairs": [
    ["[", "]"],
    ["{", "}"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"],
    ["<", ">"],
    ["«", "»"]
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["{", "}"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"],
    ["<", ">"],
    ["«", "»"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(Section|SECTION|Region|REGION|Step|STEP)\\b.*$|^\\s*\\[[^\\]]+\\]\\s*$",
      "end": "^\\s*---\\s*$"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\$\\-\\=\\+\\[\\{\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}
